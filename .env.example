# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creatorlab
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── OpenAI (Phase 4) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Client URL (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── AWS S3 (Optional – Phase 3+) ────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ─── Stripe (Phase 3) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
