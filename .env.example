# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=creatorlab
DB_USER=postgres
DB_PASSWORD=your_password_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── OpenAI (Phase 4) ────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Social Auth (Google + TikTok) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/callback
GOOGLE_OAUTH_SCOPES=openid email profile
# Optional overrides
# GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/auth/oauth/callback
TIKTOK_OAUTH_SCOPES=user.info.basic
# Optional overrides
# TIKTOK_OAUTH_AUTHORIZE_URL=https://www.tiktok.com/v2/auth/authorize/
# TIKTOK_OAUTH_TOKEN_URL=https://open.tiktokapis.com/v2/oauth/token/
# TIKTOK_USERINFO_URL=https://open.tiktokapis.com/v2/user/info/?fields=open_id,display_name,avatar_url

# ─── Client URL (CORS) ───────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ─── AWS S3 (Optional – Phase 3+) ────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=

# ─── Stripe (Phase 3) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── cele.bio Integration (OAuth + Publish) ─────────────────────────────────
CELEBIO_BASE_URL=https://cele.bio
CELEBIO_CLIENT_ID=
CELEBIO_CLIENT_SECRET=
CELEBIO_REDIRECT_URI=http://localhost:3000/auth/integrations/celebio/callback
CELEBIO_OAUTH_SCOPES=products.write files.write products.read
# Optional overrides
# CELEBIO_OAUTH_AUTHORIZE_URL=https://cele.bio/oauth/authorize
# CELEBIO_OAUTH_TOKEN_URL=https://cele.bio/oauth/token
# CELEBIO_IMPORT_URL=https://cele.bio/v1/imports/ebook
CELEBIO_WEBHOOK_SECRET=

# Used to encrypt stored OAuth tokens at rest
INTEGRATION_ENCRYPTION_KEY=replace_with_a_long_random_secret

# ─── Gumroad Integration ─────────────────────────────────────────────────────
GUMROAD_CLIENT_ID=
GUMROAD_CLIENT_SECRET=
GUMROAD_REDIRECT_URI=http://localhost:3000/auth/integrations/gumroad/callback
GUMROAD_OAUTH_SCOPES=view_profile edit_products
# Optional overrides
# GUMROAD_OAUTH_AUTHORIZE_URL=https://gumroad.com/oauth/authorize
# GUMROAD_OAUTH_TOKEN_URL=https://gumroad.com/oauth/token
# GUMROAD_PRODUCT_IMPORT_URL=https://api.gumroad.com/v2/products
# GUMROAD_PROFILE_URL=https://api.gumroad.com/v2/user

# ─── ConvertKit Integration ──────────────────────────────────────────────────
CONVERTKIT_CLIENT_ID=
CONVERTKIT_CLIENT_SECRET=
CONVERTKIT_REDIRECT_URI=http://localhost:3000/auth/integrations/convertkit/callback
CONVERTKIT_OAUTH_SCOPES=public
# Optional overrides
# CONVERTKIT_OAUTH_AUTHORIZE_URL=https://app.convertkit.com/oauth/authorize
# CONVERTKIT_OAUTH_TOKEN_URL=https://app.convertkit.com/oauth/token
# CONVERTKIT_PROFILE_URL=https://api.convertkit.com/v4/account
# CONVERTKIT_EVENT_URL=https://api.convertkit.com/v4/events

# ─── Zapier Integration ──────────────────────────────────────────────────────
# Optional global fallback webhook if users don't provide their own
ZAPIER_EVENT_URL=
